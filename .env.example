# =============================================================================
# SST Manager — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Branding (white-label) ---
# Identidade visível do produto. Sem isso, roda neutro (só "SST Manager").
# Logos: troque os arquivos em public/logos/brand-*.svg (e public/icon.svg)
# pelos do cliente, ou aponte os caminhos opcionais abaixo.
NEXT_PUBLIC_BRAND_APP_NAME=SST Manager
NEXT_PUBLIC_BRAND_COMPANY_NAME=
NEXT_PUBLIC_BRAND_COMPANY_LEGAL=
NEXT_PUBLIC_BRAND_EMAIL_DOMAIN=exemplo.com.br
NEXT_PUBLIC_BRAND_PEOPLE_NAME=People (RH)
NEXT_PUBLIC_BRAND_THEME_COLOR=#1e293b
# Opcionais (defaults apontam para public/logos/brand-*.svg):
# NEXT_PUBLIC_BRAND_LOGO_FULL_LIGHT=/logos/brand-claro.svg
# NEXT_PUBLIC_BRAND_LOGO_FULL_DARK=/logos/brand-escuro.svg
# NEXT_PUBLIC_BRAND_LOGO_ICON_LIGHT=/logos/brand-icone-principal.svg
# NEXT_PUBLIC_BRAND_LOGO_ICON_DARK=/logos/brand-icone-branco.svg
# NEXT_PUBLIC_BRAND_LOGO_FULL_ASPECT=5

# --- Anthropic (classificação de risco via IA) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Cron / Jobs ---
CRON_SECRET=gere-um-uuid-aqui

# --- E-mail (Resend) — notificações de vencimento ---
# Cron diário /api/cron/notificar-vencimentos. Sem RESEND_API_KEY o cron roda
# mas não envia (apenas loga). EMAIL_FROM precisa ser remetente verificado no Resend.
RESEND_API_KEY=re_...
EMAIL_FROM=SST Manager <sst-manager@exemplo.com.br>

# --- Integração com o People (RH) ---
# Segredo HMAC do webhook que o People chama (POST /api/integr/people/webhook).
# Sem ele, o webhook responde 503 (integração inativa). Use uma string longa
# e idêntica à configurada no People.
PEOPLE_WEBHOOK_SECRET=gere-um-segredo-longo-aqui
# Chave que o People usa para LER nossas APIs (GET /api/integr/v1/...).
PEOPLE_API_KEY=gere-uma-api-key-aqui

# --- Logger (opcional) ---
# LOG_LEVEL=debug | info | warn | error
# LOG_FORMAT=json | pretty
